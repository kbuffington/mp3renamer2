{
    "name": "mp3renamer2",
    "version": "0.1.0",
    "description": "An mp3 renamer/tagger/metadata retriever/artwork downloader",
    "main": "main.js",
    "scripts": {
        "ng": "ng",
        "build": "ng build",
        "build:win": "npm run build && npx electron-packager . --platform=win32 --arch=x64 --ignore=\"(e2e|node_modules/.cache)\" --overwrite",
        "build:osx": "npm run build && npx electron-packager . --platform=darwin --arch=x64 --ignore=\"(e2e|node_modules/.cache)\" --overwrite",
        "deploy:win": "npm run move && npm run delete && npm run rename",
        "move": "xcopy mp3renamer2-win32-x64 H:\\mp3renamer2-new /E/H/C/I",
        "delete": "rd /S /Q h:\\mp3renamer2 || echo \"Directory does not exist\"",
        "rename": "ren H:\\mp3renamer2-new mp3renamer2",
        "test": "ng test",
        "lint": "ng lint",
        "postinstall": "ngcc",
        "start-id3": "tsc --module commonjs ../node-id3/index.ts; electron .",
        "start": "ng serve"
    },
    "private": true,
    "dependencies": {
        "@angular/cdk": "^19.2.19",
        "@cds/city": "^1.1.0",
        "@cds/core": "^6.17.0",
        "@clr/angular": "^17.12.2",
        "@clr/ui": "^17.12.2",
        "@electron/remote": "^2.1.3",
        "electron-dl": "^3.5.2",
        "node-id3tag": "^0.9.8"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^19.2.19",
        "@angular/animations": "^19.2.18",
        "@angular/cli": "^21.2.0",
        "@angular/common": "^19.2.18",
        "@angular/compiler": "^19.2.18",
        "@angular/compiler-cli": "^19.2.18",
        "@angular/core": "^19.2.18",
        "@angular/forms": "^19.2.18",
        "@angular/language-service": "^19.2.18",
        "@angular/platform-browser": "^19.2.18",
        "@angular/platform-browser-dynamic": "^19.2.18",
        "@angular/router": "^19.2.18",
        "@types/diff-match-patch": "^1.0.32",
        "@types/jasmine": "~3.6.0",
        "@types/jasminewd2": "^2.0.8",
        "@types/node": "^14.17.32",
        "@typescript-eslint/eslint-plugin": "^7.8.0",
        "@typescript-eslint/parser": "^7.8.0",
        "@webcomponents/custom-elements": "^1.4.3",
        "@webcomponents/webcomponentsjs": "^2.0.0",
        "core-js": "^2.6.12",
        "diff-match-patch": "^1.0.5",
        "electron": "^40.2.1",
        "electron-packager": "^17.1.1",
        "eslint": "^9.2.0",
        "eslint-config-google": "^0.14.0",
        "eslint-plugin-import": "^2.29.1",
        "jasmine-core": "~3.6.0",
        "jasmine-spec-reporter": "~5.0.0",
        "karma": "~6.3.4",
        "karma-chrome-launcher": "~3.1.0",
        "karma-coverage-istanbul-reporter": "~3.0.2",
        "karma-jasmine": "~4.0.0",
        "karma-jasmine-html-reporter": "^1.5.0",
        "protractor": "~7.0.0",
        "rxjs": "^7.8.2",
        "ts-node": "~5.0.1",
        "tslib": "^2.0.0",
        "typescript": "^5.3.3",
        "zone.js": "~0.15.1"
    }
}
